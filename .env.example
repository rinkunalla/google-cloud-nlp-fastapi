# ──────────────── Google Cloud Authentication ────────────────
# Option 1: API Key (recommended — simplest setup)
# Get your key from: Google Cloud Console → APIs & Services → Credentials → Create Credentials → API Key
GOOGLE_CLOUD_API_KEY="Input Your Google Cloud API Key Here"

# Option 2: Service Account JSON file (alternative)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ──────────────── App Authentication ─────────────────────────
# API Keys for accessing YOUR endpoints (comma-separated)
API_KEYS="Input Your Custom App Keys Here. use comma as separator to add more keys"

# ──────────────── Rate Limiting ──────────────────────────────
# Format: "requests/period" (e.g., "10/minute", "100/hour")
RATE_LIMIT=10/minute
